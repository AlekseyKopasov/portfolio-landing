# SMTP (Яндекс: пароль приложения в настройках почты)
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USER=your@yandex.ru
SMTP_PASS=
MAIL_FROM=your@yandex.ru
MAIL_TO=your@yandex.ru

# --- AI (бесплатно: достаточно одного ключа) ---

# Рекомендуется: Groq — бесплатный tier, OpenAI-совместимый API
# https://console.groq.com/keys
GROQ_API_KEY=
# GROQ_MODEL=llama-3.1-8b-instant

# Альтернатива: Google Gemini — бесплатный tier
# https://aistudio.google.com/apikey
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# Платный вариант (не обязателен)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Принудительный провайдер: groq | gemini | openai
# AI_PROVIDER=groq
